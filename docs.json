{
  "$schema": "https://mintlify.com/docs.json",
  "name": "EasyGoDocs",
  "theme": "palm",
  "colors": {
    "primary": "#6366f1",
    "light": "#818cf8",
    "dark": "#4f46e5"
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/EasyGoDocs/easygodocs"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/EasyGoDocs/easygodocs"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "features"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/json-structure",
              "concepts/tsx-templates",
              "concepts/navigation"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/docker",
              "guides/git",
              "guides/nodejs",
              "guides/system-tools"
            ]
          },
          {
            "group": "Contributing",
            "pages": [
              "contributing/guide",
              "contributing/code-of-conduct"
            ]
          }
        ]
      },
      {
        "tab": "Documentation Library",
        "groups": [
          {
            "group": "Development Tools",
            "pages": [
              "library/install-git-ubuntu",
              "library/install-nodejs-apt",
              "library/install-nodejs-nvm",
              "library/install-docker-ubuntu",
              "library/install-docker-compose"
            ]
          },
          {
            "group": "System Tools",
            "pages": [
              "library/install-zsh",
              "library/install-oh-my-zsh",
              "library/install-tmux",
              "library/install-htop",
              "library/install-ncdu",
              "library/check-disk-space",
              "library/find-ip-address",
              "library/kill-process-port",
              "library/ubuntu-package-update"
            ]
          },
          {
            "group": "Frameworks & Libraries",
            "pages": [
              "library/react"
            ]
          },
          {
            "group": "Utilities",
            "pages": [
              "library/generate-ssh-key-github",
              "library/chrome-download"
            ]
          }
        ]
      }
    ]
  }
}
